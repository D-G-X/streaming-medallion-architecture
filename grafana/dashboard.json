        {
          "dataset": "market_data",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "dffhkbexkmfi8d"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('minute', timestamp) AS \"time\",\n  (array_agg(price_usd ORDER BY timestamp ASC))[1] AS \"open\",\n  MAX(price_usd) AS \"high\",\n  MIN(price_usd) AS \"low\",\n  (array_agg(price_usd ORDER BY timestamp DESC))[1] AS \"close\"\nFROM crypto_market_data\nWHERE coin = 'bitcoin' AND $__timeFilter(timestamp)\nGROUP BY 1\nORDER BY 1 ASC;",
          "refId": "candle stick",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        },
        {
          "dataset": "market_data",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "dffhkbexkmfi8d"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "WITH ohlc AS (\n  SELECT\n    date_trunc('minute', timestamp) AS \"time\",\n    (array_agg(price_usd ORDER BY timestamp DESC))[1] AS \"close\"\n  FROM crypto_market_data\n  WHERE coin = 'bitcoin' AND $__timeFilter(timestamp)\n  GROUP BY 1\n)\nSELECT\n  time,\n  AVG(close) OVER (ORDER BY time ROWS BETWEEN 4 PRECEDING AND CURRENT ROW) AS \"moving_average\"\nFROM ohlc\nORDER BY time ASC;",
          "refId": "Moving average",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "BTC Candle Stick Graph with 1-minute Moving Average",
      "type": "candlestick"
    },
